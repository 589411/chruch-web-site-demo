{
  "name": "church-website-sdd",
  "version": "1.0.0",
  "description": "教會官網 SDD 建構系統 - Specification-Driven Development for Church Websites",
  "main": "index.js",
  "scripts": {
    "build:church": "node sdd-builder/church-builder.js",
    "validate": "node scripts/validate-config.js",
    "generate": "node generators/website-generator.js",
    "preview:stage1": "node scripts/preview.js stage1",
    "preview:stage2": "node scripts/preview.js stage2",
    "preview:stage3": "node scripts/preview.js stage3",
    "preview:stage4": "node scripts/preview.js stage4",
    "dev": "cd output/website && npm run dev",
    "build": "cd output/website && npm run build",
    "deploy": "node scripts/deploy.js",
    "deploy:netlify": "netlify deploy --prod --dir=output/website/out",
    "deploy:vercel": "vercel --prod output/website",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "church",
    "website",
    "sdd",
    "specification-driven",
    "nextjs",
    "taiwan",
    "教會",
    "官網"
  ],
  "author": "Church SDD Team",
  "license": "MIT",
  "dependencies": {
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "framer-motion": "^11.0.3",
    "lucide-react": "^0.312.0",
    "date-fns": "^3.2.0",
    "ajv": "^8.12.0",
    "dotenv": "^16.4.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "prettier": "^3.2.4",
    "jest": "^29.7.0",
    "netlify-cli": "^17.15.0",
    "vercel": "^33.4.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/church-website-sdd.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/church-website-sdd/issues"
  },
  "homepage": "https://github.com/your-org/church-website-sdd#readme"
}
