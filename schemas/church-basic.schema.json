{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://church-sdd.org/schemas/church-basic.json",
  "title": "教會基礎資訊 Schema",
  "description": "階段 1：建構網站骨架的基礎資訊",
  "type": "object",
  "required": [
    "churchInfo",
    "address",
    "schedule",
    "mission",
    "team",
    "contact",
    "branding"
  ],
  "properties": {
    "churchInfo": {
      "type": "object",
      "required": ["fullName", "shortName"],
      "properties": {
        "fullName": {
          "type": "string",
          "maxLength": 30,
          "description": "教會全稱"
        },
        "shortName": {
          "type": "string",
          "maxLength": 15,
          "description": "教會簡稱"
        },
        "englishName": {
          "type": "string",
          "description": "英文名稱（選填）"
        }
      }
    },
    "address": {
      "type": "object",
      "required": ["street", "city"],
      "properties": {
        "street": {
          "type": "string",
          "description": "街道地址"
        },
        "city": {
          "type": "string",
          "description": "城市"
        },
        "district": {
          "type": "string",
          "description": "區域"
        },
        "zipCode": {
          "type": "string",
          "description": "郵遞區號"
        },
        "googleMapsUrl": {
          "type": "string",
          "format": "uri",
          "description": "Google Maps 連結"
        },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            "lng": {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            }
          }
        }
      }
    },
    "schedule": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "day", "time"],
        "properties": {
          "name": {
            "type": "string",
            "description": "聚會名稱"
          },
          "day": {
            "type": "string",
            "enum": [
              "週日",
              "週一",
              "週二",
              "週三",
              "週四",
              "週五",
              "週六"
            ]
          },
          "time": {
            "type": "string",
            "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]-([0-1]?[0-9]|2[0-3]):[0-5][0-9]$",
            "description": "時間區間（HH:MM-HH:MM）"
          },
          "location": {
            "type": "string",
            "description": "地點"
          },
          "description": {
            "type": "string",
            "description": "說明"
          },
          "recurring": {
            "type": "string",
            "enum": ["weekly", "biweekly", "monthly"],
            "default": "weekly"
          }
        }
      }
    },
    "mission": {
      "type": "object",
      "required": ["mission"],
      "properties": {
        "mission": {
          "type": "string",
          "minLength": 10,
          "maxLength": 100,
          "description": "使命陳述"
        },
        "vision": {
          "type": "string",
          "minLength": 10,
          "maxLength": 80,
          "description": "異象"
        },
        "values": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "type": "string"
          },
          "description": "核心價值"
        }
      }
    },
    "team": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["name", "title"],
        "properties": {
          "name": {
            "type": "string",
            "description": "姓名"
          },
          "title": {
            "type": "string",
            "description": "職稱"
          },
          "photo": {
            "type": "string",
            "format": "uri",
            "description": "照片 URL"
          },
          "bio": {
            "type": "string",
            "minLength": 50,
            "maxLength": 150,
            "description": "簡介"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email"
          },
          "order": {
            "type": "integer",
            "minimum": 1,
            "description": "顯示順序"
          }
        }
      }
    },
    "contact": {
      "type": "object",
      "required": ["phone", "email"],
      "properties": {
        "phone": {
          "type": "string",
          "description": "電話"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email"
        },
        "line": {
          "type": "string",
          "description": "LINE ID"
        },
        "facebook": {
          "type": "string",
          "format": "uri",
          "description": "Facebook 連結"
        },
        "instagram": {
          "type": "string",
          "format": "uri",
          "description": "Instagram 連結"
        },
        "youtube": {
          "type": "string",
          "format": "uri",
          "description": "YouTube 連結"
        },
        "officeHours": {
          "type": "string",
          "description": "辦公時間"
        }
      }
    },
    "branding": {
      "type": "object",
      "required": ["primaryColor", "style"],
      "properties": {
        "primaryColor": {
          "type": "string",
          "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
          "description": "主色系"
        },
        "secondaryColor": {
          "type": "string",
          "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
          "description": "輔助色"
        },
        "accentColor": {
          "type": "string",
          "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
          "description": "強調色"
        },
        "logoUrl": {
          "type": "string",
          "format": "uri",
          "description": "Logo URL"
        },
        "fontFamily": {
          "type": "string",
          "enum": [
            "Noto Sans TC",
            "Noto Serif TC",
            "Microsoft JhengHei",
            "PingFang TC",
            "Source Han Sans"
          ],
          "description": "字體"
        },
        "style": {
          "type": "string",
          "enum": ["modern", "elegant", "traditional"],
          "description": "整體風格"
        }
      }
    },
    "targetAudience": {
      "type": "object",
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "families",
              "youth",
              "elderly",
              "children",
              "students",
              "newcomers",
              "immigrants"
            ]
          }
        },
        "ageGroups": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["0-12", "13-18", "18-25", "25-40", "40-60", "60+"]
          }
        },
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["zh-TW", "zh-CN", "en", "id", "th", "vi"]
          }
        },
        "needs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mobileUsagePercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "手機使用比例（%）"
        }
      }
    }
  }
}
