{
  "stage1": {
    "name": "基礎資訊",
    "description": "建構網站骨架與品牌定位",
    "outputFile": "church-basic.json",
    "questions": [
      {
        "id": "Q1",
        "question": "教會全稱與簡稱？",
        "description": "例：台北信望愛基督教會 / 信望愛",
        "fields": [
          {
            "name": "fullName",
            "type": "text",
            "required": true,
            "maxLength": 30,
            "placeholder": "台北信望愛基督教會"
          },
          {
            "name": "shortName",
            "type": "text",
            "required": true,
            "maxLength": 15,
            "placeholder": "信望愛教會"
          },
          {
            "name": "englishName",
            "type": "text",
            "required": false,
            "placeholder": "Faith Hope Love Church Taipei"
          }
        ],
        "validation": {
          "fullName": "中文全稱不超過30字",
          "shortName": "簡稱不超過15字"
        },
        "llmHints": [
          "檢查是否包含教會類型（基督教會/長老教會等）",
          "建議提供英文名稱以提升SEO"
        ]
      },
      {
        "id": "Q2",
        "question": "完整地址與 Google Maps 連結？",
        "description": "請提供教會地址和 Google Maps 分享連結",
        "fields": [
          {
            "name": "street",
            "type": "text",
            "required": true,
            "placeholder": "台北市中正區羅斯福路一段1號"
          },
          {
            "name": "city",
            "type": "text",
            "required": true,
            "placeholder": "台北市"
          },
          {
            "name": "district",
            "type": "text",
            "required": false,
            "placeholder": "中正區"
          },
          {
            "name": "zipCode",
            "type": "text",
            "required": false,
            "placeholder": "100"
          },
          {
            "name": "googleMapsUrl",
            "type": "url",
            "required": false,
            "placeholder": "https://goo.gl/maps/xxxxx"
          }
        ],
        "validation": {
          "googleMapsUrl": "必須是有效的 Google Maps 連結"
        },
        "llmHints": [
          "可以從地址自動生成座標",
          "建議加入交通指引說明"
        ]
      },
      {
        "id": "Q3",
        "question": "聚會時間表？",
        "description": "請列出常態性聚會（主日崇拜、禱告會等）",
        "fields": [
          {
            "name": "schedule",
            "type": "array",
            "required": true,
            "minItems": 1,
            "itemStructure": {
              "name": "聚會名稱",
              "day": "週幾",
              "time": "時間區間（HH:MM-HH:MM）",
              "location": "地點",
              "description": "說明（可選）",
              "recurring": "weekly/biweekly/monthly"
            },
            "example": {
              "name": "主日崇拜",
              "day": "週日",
              "time": "10:00-12:00",
              "location": "主堂",
              "description": "英語/華語同步翻譯",
              "recurring": "weekly"
            }
          }
        ],
        "validation": {
          "time": "必須是 HH:MM-HH:MM 格式",
          "minItems": "至少需要主日崇拜時間"
        },
        "llmHints": [
          "建議提供 2-5 個常態聚會",
          "可加入特殊聚會（如月末愛宴）"
        ]
      },
      {
        "id": "Q4",
        "question": "使命陳述？",
        "description": "教會的使命、異象與核心價值",
        "fields": [
          {
            "name": "mission",
            "type": "textarea",
            "required": true,
            "minLength": 10,
            "maxLength": 100,
            "placeholder": "活出基督的愛，建造榮神益人的教會"
          },
          {
            "name": "vision",
            "type": "textarea",
            "required": false,
            "minLength": 10,
            "maxLength": 80,
            "placeholder": "成為社區的祝福，傳揚福音直到地極"
          },
          {
            "name": "values",
            "type": "array",
            "required": false,
            "minItems": 3,
            "maxItems": 5,
            "itemType": "text",
            "example": [
              "敬拜：以心靈誠實敬拜神",
              "團契：彼此相愛的群體",
              "服事：發揮恩賜服事人群",
              "傳福音：分享耶穌的好消息"
            ]
          }
        ],
        "validation": {
          "mission": "使命 1-2 句（20-50 字）",
          "vision": "異象 1 句（15-30 字）",
          "values": "核心價值 3-5 項"
        },
        "llmHints": [
          "使命應簡潔有力，易於記憶",
          "異象應具體且可達成"
        ]
      },
      {
        "id": "Q5",
        "question": "領導團隊？",
        "description": "牧者與同工資訊（姓名、職稱、簡介）",
        "fields": [
          {
            "name": "team",
            "type": "array",
            "required": true,
            "minItems": 3,
            "itemStructure": {
              "name": "姓名",
              "title": "職稱",
              "photo": "照片URL",
              "bio": "簡介（50-150字）",
              "email": "Email（可選）",
              "order": "顯示順序"
            },
            "example": {
              "name": "王恩典",
              "title": "主任牧師",
              "photo": "/images/pastor-wang.jpg",
              "bio": "神學院道學碩士，牧養教會15年，熱愛青年事工",
              "email": "pastor@church.org",
              "order": 1
            }
          }
        ],
        "validation": {
          "minItems": "至少 1 位主要牧者 + 2 位同工",
          "photo": "建議 400x400px 正方形",
          "bio": "簡介 50-150 字"
        },
        "llmHints": [
          "照片建議使用專業形象照",
          "可加入服事領域與聯絡方式"
        ]
      },
      {
        "id": "Q6",
        "question": "聯絡資訊？",
        "description": "電話、Email、社交媒體等聯絡方式",
        "fields": [
          {
            "name": "phone",
            "type": "tel",
            "required": true,
            "placeholder": "02-2345-6789"
          },
          {
            "name": "email",
            "type": "email",
            "required": true,
            "placeholder": "info@faithhopelove.org"
          },
          {
            "name": "line",
            "type": "text",
            "required": false,
            "placeholder": "@faithhopelove"
          },
          {
            "name": "facebook",
            "type": "url",
            "required": false,
            "placeholder": "https://facebook.com/faithhopelove"
          },
          {
            "name": "instagram",
            "type": "url",
            "required": false,
            "placeholder": "https://instagram.com/faithhopelove"
          },
          {
            "name": "youtube",
            "type": "url",
            "required": false,
            "placeholder": "https://youtube.com/@faithhopelove"
          },
          {
            "name": "officeHours",
            "type": "text",
            "required": false,
            "placeholder": "週二至週五 10:00-17:00"
          }
        ],
        "validation": {
          "email": "必須是有效的 Email 格式",
          "facebook": "必須是有效的 Facebook URL",
          "minContacts": "至少 2 種聯絡方式"
        },
        "llmHints": [
          "建議提供多種聯絡管道",
          "社交媒體可增加觸及率"
        ]
      },
      {
        "id": "Q7",
        "question": "品牌風格？",
        "description": "主要色系、Logo、字體與整體風格",
        "fields": [
          {
            "name": "primaryColor",
            "type": "color",
            "required": true,
            "default": "#3B82F6",
            "placeholder": "#3B82F6"
          },
          {
            "name": "secondaryColor",
            "type": "color",
            "required": false,
            "default": "#10B981",
            "placeholder": "#10B981"
          },
          {
            "name": "accentColor",
            "type": "color",
            "required": false,
            "default": "#F59E0B",
            "placeholder": "#F59E0B"
          },
          {
            "name": "logoUrl",
            "type": "url",
            "required": false,
            "placeholder": "/images/logo.svg"
          },
          {
            "name": "fontFamily",
            "type": "select",
            "required": true,
            "default": "Noto Sans TC",
            "options": [
              "Noto Sans TC",
              "Noto Serif TC",
              "Microsoft JhengHei",
              "PingFang TC",
              "Source Han Sans"
            ]
          },
          {
            "name": "style",
            "type": "select",
            "required": true,
            "default": "modern",
            "options": [
              {
                "value": "modern",
                "label": "現代風格",
                "description": "簡約、大量留白、現代字體"
              },
              {
                "value": "elegant",
                "label": "優雅風格",
                "description": "優雅、襯線字體、漸層"
              },
              {
                "value": "traditional",
                "label": "傳統風格",
                "description": "經典、深色系、莊重"
              }
            ]
          }
        ],
        "validation": {
          "primaryColor": "必須是有效的 HEX 色碼",
          "contrast": "檢查對比度（無障礙標準）"
        },
        "llmHints": [
          "可從 Logo 自動提取主色",
          "提供配色建議",
          "確保文字與背景對比度足夠"
        ]
      },
      {
        "id": "Q8",
        "question": "目標訪客？",
        "description": "主要服事對象與語言需求",
        "fields": [
          {
            "name": "primary",
            "type": "multiselect",
            "required": true,
            "options": [
              "families",
              "youth",
              "elderly",
              "children",
              "students",
              "newcomers",
              "immigrants"
            ],
            "labels": {
              "families": "家庭",
              "youth": "青年",
              "elderly": "長者",
              "children": "兒童",
              "students": "學生",
              "newcomers": "慕道友",
              "immigrants": "新移民"
            }
          },
          {
            "name": "ageGroups",
            "type": "multiselect",
            "required": false,
            "options": ["0-12", "13-18", "18-25", "25-40", "40-60", "60+"]
          },
          {
            "name": "languages",
            "type": "multiselect",
            "required": true,
            "default": ["zh-TW"],
            "options": ["zh-TW", "zh-CN", "en", "id", "th", "vi"]
          },
          {
            "name": "needs",
            "type": "multiselect",
            "required": false,
            "options": [
              "尋找教會",
              "了解信仰",
              "參與活動",
              "尋求幫助",
              "服事機會"
            ]
          },
          {
            "name": "mobileUsagePercent",
            "type": "number",
            "required": true,
            "default": 70,
            "min": 0,
            "max": 100,
            "unit": "%"
          }
        ],
        "validation": {
          "primary": "至少選擇 1 個主要對象",
          "languages": "至少選擇 1 種語言"
        },
        "llmHints": [
          "手機使用率 >70% → 行動優先設計",
          "青年為主 → 加強社交媒體整合",
          "多語需求 → 啟用多語言功能"
        ]
      }
    ]
  },
  "stage2": {
    "name": "核心功能",
    "description": "啟用 80% 教會都需要的功能",
    "outputFile": "core-features.json",
    "questions": [
      {
        "id": "Q9",
        "question": "確認核心功能",
        "description": "請選擇要啟用的核心功能（可複選）",
        "fields": [
          {
            "name": "selectedFeatures",
            "type": "multiselect",
            "required": true,
            "minItems": 4,
            "options": [
              {
                "value": "schedule",
                "label": "聚會時間表",
                "description": "動態顯示各類聚會",
                "complexity": "low",
                "necessity": 5
              },
              {
                "value": "sermons",
                "label": "講道信息",
                "description": "音頻/影片播放器",
                "complexity": "medium",
                "necessity": 5
              },
              {
                "value": "events",
                "label": "活動日曆",
                "description": "活動預覽+報名",
                "complexity": "medium",
                "necessity": 4
              },
              {
                "value": "contact",
                "label": "聯絡表單",
                "description": "即時通知",
                "complexity": "low",
                "necessity": 5
              },
              {
                "value": "donation",
                "label": "奉獻功能",
                "description": "QR碼+線上支付",
                "complexity": "medium-high",
                "necessity": 4
              },
              {
                "value": "social",
                "label": "社交媒體",
                "description": "FB/IG/YouTube 嵌入",
                "complexity": "low",
                "necessity": 4
              }
            ]
          }
        ],
        "validation": {
          "minItems": "至少選擇 4 項",
          "contactRequired": "建議啟用「聯絡表單」"
        },
        "llmHints": [
          "評估總開發時間",
          "檢查功能相依性"
        ]
      },
      {
        "id": "Q10",
        "question": "講道主要格式？",
        "description": "影片、音頻還是文字？",
        "conditionalOn": {
          "Q9.selectedFeatures": "includes:sermons"
        },
        "fields": [
          {
            "name": "primaryFormat",
            "type": "select",
            "required": true,
            "default": "video",
            "options": [
              {
                "value": "video",
                "label": "影片",
                "description": "YouTube 嵌入（推薦）"
              },
              {
                "value": "audio",
                "label": "音頻",
                "description": "MP3 播放器"
              },
              {
                "value": "text",
                "label": "文字",
                "description": "講章文字版"
              }
            ]
          },
          {
            "name": "platforms",
            "type": "multiselect",
            "required": false,
            "options": ["youtube", "vimeo", "自行上傳"]
          },
          {
            "name": "enableDownload",
            "type": "boolean",
            "required": false,
            "default": true,
            "label": "允許下載"
          },
          {
            "name": "showNotes",
            "type": "boolean",
            "required": false,
            "default": true,
            "label": "顯示講道筆記"
          },
          {
            "name": "categories",
            "type": "array",
            "required": false,
            "default": ["主日信息", "專題講座"],
            "itemType": "text"
          },
          {
            "name": "displayStyle",
            "type": "select",
            "required": false,
            "default": "grid",
            "options": ["grid", "list", "carousel"]
          }
        ]
      },
      {
        "id": "Q11",
        "question": "奉獻需求？",
        "description": "僅 QR 碼或完整線上支付？",
        "conditionalOn": {
          "Q9.selectedFeatures": "includes:donation"
        },
        "fields": [
          {
            "name": "methods",
            "type": "array",
            "required": true,
            "minItems": 1,
            "itemOptions": [
              {
                "type": "qrcode",
                "label": "QR Code 轉帳",
                "fields": {
                  "name": "顯示名稱",
                  "image": "QR Code 圖片",
                  "bankInfo": {
                    "bank": "銀行名稱",
                    "account": "帳號",
                    "name": "戶名"
                  }
                }
              },
              {
                "type": "online",
                "label": "線上支付",
                "fields": {
                  "provider": ["stripe", "newebpay", "ecpay"],
                  "currency": "TWD",
                  "enableRecurring": "是否支援定期定額"
                }
              }
            ]
          },
          {
            "name": "taxReceipt",
            "type": "boolean",
            "required": false,
            "default": false,
            "label": "提供奉獻收據"
          }
        ],
        "llmHints": [
          "僅 QR 碼：簡單、免費",
          "線上支付：需申請金流（手續費 2.9%）",
          "Stripe 適合國際捐款",
          "綠界/藍新適合台灣本地"
        ]
      },
      {
        "id": "Q12",
        "question": "活動日曆配置",
        "description": "活動管理與報名設定",
        "conditionalOn": {
          "Q9.selectedFeatures": "includes:events"
        },
        "fields": [
          {
            "name": "provider",
            "type": "select",
            "required": true,
            "default": "google",
            "options": [
              {
                "value": "google",
                "label": "Google Calendar",
                "description": "免費、易整合"
              },
              {
                "value": "airtable",
                "label": "Airtable",
                "description": "功能豐富"
              },
              {
                "value": "notion",
                "label": "Notion",
                "description": "易於編輯"
              }
            ]
          },
          {
            "name": "calendarId",
            "type": "text",
            "required": false,
            "placeholder": "xxxxx@group.calendar.google.com"
          },
          {
            "name": "enableRegistration",
            "type": "boolean",
            "required": false,
            "default": true,
            "label": "啟用線上報名"
          },
          {
            "name": "registrationProvider",
            "type": "select",
            "required": false,
            "conditionalOn": {
              "enableRegistration": true
            },
            "options": ["Google Forms", "Airtable", "內建表單"]
          }
        ]
      },
      {
        "id": "Q13",
        "question": "聯絡表單配置",
        "description": "表單欄位與通知設定",
        "conditionalOn": {
          "Q9.selectedFeatures": "includes:contact"
        },
        "fields": [
          {
            "name": "provider",
            "type": "select",
            "required": true,
            "default": "emailjs",
            "options": [
              {
                "value": "emailjs",
                "label": "EmailJS",
                "description": "免費、簡單"
              },
              {
                "value": "formspree",
                "label": "Formspree",
                "description": "穩定、易用"
              },
              {
                "value": "google-sheets",
                "label": "Google Sheets",
                "description": "自動記錄"
              }
            ]
          },
          {
            "name": "fields",
            "type": "multiselect",
            "required": true,
            "default": ["name", "email", "phone", "message"],
            "options": [
              "name",
              "email",
              "phone",
              "subject",
              "message",
              "preferredContact",
              "bestTime"
            ]
          },
          {
            "name": "notifyEmail",
            "type": "email",
            "required": true,
            "placeholder": "info@church.org"
          },
          {
            "name": "autoReply",
            "type": "boolean",
            "required": false,
            "default": true,
            "label": "自動回覆"
          }
        ]
      },
      {
        "id": "Q14",
        "question": "社交媒體整合",
        "description": "嵌入社交媒體內容",
        "conditionalOn": {
          "Q9.selectedFeatures": "includes:social"
        },
        "fields": [
          {
            "name": "enableFeed",
            "type": "boolean",
            "required": false,
            "default": true,
            "label": "顯示最新貼文"
          },
          {
            "name": "platforms",
            "type": "multiselect",
            "required": true,
            "options": ["facebook", "instagram", "youtube", "twitter"]
          },
          {
            "name": "displayStyle",
            "type": "select",
            "required": false,
            "default": "grid",
            "options": ["grid", "carousel", "list"]
          }
        ]
      }
    ]
  },
  "stage3": {
    "name": "進階功能",
    "description": "依需求加入特色功能",
    "outputFile": "advanced-features.json",
    "questions": [
      {
        "id": "Q15",
        "question": "選擇進階功能",
        "description": "從下列功能中選擇需要的（可複選）",
        "fields": [
          {
            "name": "selectedFeatures",
            "type": "multiselect",
            "required": false,
            "options": [
              {
                "value": "prayer",
                "label": "代禱事項",
                "category": "互動",
                "complexity": "medium",
                "cost": "low"
              },
              {
                "value": "testimonies",
                "label": "信仰見證",
                "category": "互動",
                "complexity": "medium",
                "cost": "low"
              },
              {
                "value": "memberPortal",
                "label": "會員系統",
                "category": "互動",
                "complexity": "high",
                "cost": "medium"
              },
              {
                "value": "registration",
                "label": "線上報名",
                "category": "互動",
                "complexity": "medium",
                "cost": "low"
              },
              {
                "value": "bulletin",
                "label": "週報系統",
                "category": "內容",
                "complexity": "low",
                "cost": "low"
              },
              {
                "value": "devotional",
                "label": "靈修資源",
                "category": "內容",
                "complexity": "low",
                "cost": "low"
              },
              {
                "value": "ministries",
                "label": "事工專欄",
                "category": "內容",
                "complexity": "low",
                "cost": "low"
              },
              {
                "value": "livestream",
                "label": "直播串流",
                "category": "技術",
                "complexity": "high",
                "cost": "medium-high"
              },
              {
